wide %>%
select(learner, rmse_median, pct_beats_zero, sign_both_rate,
rec_sg1_p50, rec_sg2_p50) %>%
arrange(rmse_median) %>%
mutate(across(where(is.numeric), ~ round(.x, 3))) %>%
print()
print(n=112)
