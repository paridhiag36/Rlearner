library(dplyr)
library(tidyr)
ml <- read.csv("telemed_metrics_long.csv")
# Filter to only the metrics you need, then pivot
# This avoids the duplicate-row problem causing all the NAs
table_metrics <- c("nmse_median", "pct_beats_zero", "sign_both_rate",
"rec_sg1_p50", "rec_sg2_p50")
wide <- ml %>%
filter(metric %in% table_metrics) %>%
pivot_wider(names_from = metric, values_from = value)
tau_var   <- 3.887^2
zero_rmse <- sqrt(tau_var + 0.70^2)
wide <- wide %>%
mutate(rmse_median = round(sqrt(nmse_median * tau_var), 2),
pct_beats_zero  = round(pct_beats_zero * 100, 1),
sign_both_rate  = round(sign_both_rate * 100, 1),
rec_sg1_p50     = round(rec_sg1_p50, 2),
rec_sg2_p50     = round(rec_sg2_p50, 2)) %>%
select(learner, rmse_median, pct_beats_zero,
sign_both_rate, rec_sg1_p50, rec_sg2_p50) %>%
arrange(rmse_median)
cat("Zero predictor RMSE:", round(zero_rmse, 2), "mmHg\n\n")
print(wide, n = 20)
write.csv(wide, "telemed_table_ready.csv", row.names = FALSE)
