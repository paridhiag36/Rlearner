rmse_p10    = sqrt(nmse_p10    * tau_var),
rmse_p90    = sqrt(nmse_p90    * tau_var)
)
# Zero predictor RMSE
zero_rmse <- sqrt(tau_var + 0.70^2)
cat("Zero predictor RMSE:", round(zero_rmse, 3), "mmHg\n")
